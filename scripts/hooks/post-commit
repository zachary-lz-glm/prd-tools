#!/usr/bin/env bash
# post-commit hook: feat/fix 提交后询问是否触发 release.sh --auto
# 生成版本号更新 + CHANGELOG + commit + tag

set -uo pipefail

# 允许通过环境变量禁用（PRD_TOOLS_NO_AUTO_RELEASE=1 git commit ...）
[ "${PRD_TOOLS_NO_AUTO_RELEASE:-}" = "1" ] && exit 0

REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"

# 获取最近一次 commit 的 subject
subject=$(git log -1 --format="%s")

# 跳过 release 提交（避免无限循环）
echo "$subject" | grep -qE '^release:' && exit 0

# 跳过非触发型提交（docs/chore/refactor 不触发发版）
echo "$subject" | grep -qE '^(feat|fix)' || exit 0

# 检测到可发版的提交
echo ""
echo "==> [post-commit] 检测到 ${subject}"

# 非交互终端时跳过（如 CI 或管道）
if [ ! -t 0 ]; then
  echo "==> [post-commit] 非交互终端，跳过发版。手动发版: scripts/release.sh --auto" >&2
  exit 0
fi

echo -n "==> [post-commit] 是否发版？[y/N] "
read -r answer
case "$answer" in
  [yY]|[yY][eE][sS])
    if ! "${REPO_ROOT}/scripts/release.sh" --auto --no-edit; then
      echo "==> [post-commit] 发版失败，可手动运行: scripts/release.sh --auto" >&2
    fi
    ;;
  *)
    echo "==> [post-commit] 跳过发版。需要时手动运行: scripts/release.sh --auto"
    ;;
esac
